# Пример переменных окружения прототип-бэкенда.
# Реальные значения задаются в Railway (Variables), в репозиторий не коммитятся.

PORT=8080

# Postgres. На Railway — ссылка на сервис: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://postgres:postgres@localhost:5432/akk?sslmode=disable

# CORS. Для same-origin через nginx-прокси можно оставить *.
# Если бэкенд на отдельном домене — укажите домен фронта.
ALLOWED_ORIGINS=*

# JWT. В проде — длинный случайный секрет (>= 32 байт).
JWT_SECRET=dev-secret-change-me-min-32-bytes-long!!
JWT_ISSUER=akk-railway
ACCESS_TTL_SECONDS=86400

# SMS (KazInfoTeh). Пустой SMS_URL → mock-режим (код пишется в лог).
# Боевые креды — только в Railway Variables.
# SMS_PROVIDER: kazinfoteh_get (старый GET/XML, боевой) | kazinfoteh_json (новый JSON).
# Боевая отправка AgroCredit идёт через старый GET-API:
#   SMS_PROVIDER=kazinfoteh_get
#   SMS_URL=http://kazinfoteh.org:9507/api
#   SMS_LOGIN=<login>  SMS_PASSWORD=<password>  SMS_ORIGINATOR=AKK
SMS_PROVIDER=kazinfoteh_get
SMS_URL=
SMS_LOGIN=
SMS_PASSWORD=
SMS_ORIGINATOR=AKK

# OTP-политика.
OTP_TTL_SECONDS=300
OTP_RATE_LIMIT_SECONDS=60
OTP_MAX_PER_HOUR=5

# Демо-режим: код возвращается в ответе (demoCode), фронт подставляет его автоматически.
# Включён по умолчанию, чтобы демо проходилось без реальной SMS.
# Когда заработает боевая SMS — выставить false (чтобы коды не светились в ответах).
DEMO_MODE=true

# eGov SSO (реальный вход, в т.ч. по ЭЦП). Включается, когда задан EGOV_TOKEN_URL.
# Пусто → /ssoEgovLogin отвечает 404, кнопка eGov на фронте работает в демо-режиме.
# Креды (CLIENT_ID/SECRET) выдаёт eGov при регистрации клиента — только в Railway Variables.
# Прод-IDP:  https://idp.egov.kz   Тест-IDP: https://test.idp.egov.kz
EGOV_CLIENT_ID=
EGOV_CLIENT_SECRET=
EGOV_TOKEN_URL=
EGOV_BASE_URL=
# Точный callback фронта, как зарегистрирован в eGov (должен совпадать байт-в-байт):
#   https://akk-portal-web-production.up.railway.app/ru/auth/egov/callback
EGOV_REDIRECT_URI=
# Host-pinning для ТЕСТОВОГО IDP (нет в публичном DNS — нужен на Railway). На проде оставить пустым.
#   EGOV_RESOLVE=test.idp.egov.kz=195.12.114.235,test.egov.kz=195.12.114.235
EGOV_RESOLVE=
